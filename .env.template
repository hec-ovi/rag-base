# ============================================================
# rag-base — Configuration
# ============================================================
# Copy to .env and edit:  cp .env.template .env
# All values below are safe defaults. Only MODELS_DIR and
# passwords need your attention before first run.
# ============================================================

# === PostgreSQL + pgvector ===
POSTGRES_DB=knowledge
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=changeme
# 5433 to avoid conflict with any existing Postgres on the host
POSTGRES_PORT=5433

# === API Server ===
API_PORT=5050
API_WORKERS=1
API_LOG_LEVEL=info

# === Embedding Model (served by TEI) ===
EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-l-v2.0
EMBEDDING_PORT=8081

# === Reranker Model (served by TEI) ===
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_PORT=8082

# === Optional GPU reranker sidecars (AMD Strix Halo / gfx1151) ===
# Both off by default. Enable one or both to make these modes selectable via
# SearchRequest.rerank_model = "bge-gpu" | "qwen-4b". Falls back silently to
# the default CPU TEI reranker if the requested sidecar is not running.
#
# To enable BGE-GPU:
#   1. docker compose --profile rerank-bge-gpu up -d
#   2. uncomment BGE_GPU_RERANKER_URL below
# To enable Qwen-4B:
#   1. docker compose --profile rerank-qwen up -d
#   2. uncomment QWEN_RERANKER_URL below
# BGE_GPU_RERANKER_URL=http://reranker-bge-gpu:80
BGE_GPU_RERANK_PORT=8083
BGE_GPU_RERANK_BATCH_SIZE=8
# QWEN_RERANKER_URL=http://reranker-qwen:80
QWEN_RERANK_PORT=8084
QWEN_RERANK_BATCH_SIZE=8
# To enable Qwen-8B (16 GiB VRAM at fp16):
#   1. docker compose --profile rerank-qwen-8b up -d
#   2. uncomment QWEN_8B_RERANKER_URL below
# QWEN_8B_RERANKER_URL=http://reranker-qwen-8b:80
QWEN_8B_RERANK_PORT=8085
QWEN_8B_RERANK_BATCH_SIZE=4

# === Model Storage ===
# Absolute path on the host where HuggingFace models are cached.
# TEI downloads here on first boot, then reuses the cache.
# Two separate dirs so embed and rerank containers don't collide.
# IMPORTANT: Use absolute paths. Example: /home/youruser/models/embeddings
EMBEDDING_MODELS_DIR=/path/to/your/models/embeddings
RERANKER_MODELS_DIR=/path/to/your/models/rerankers

# === Memgraph ===
MEMGRAPH_PORT=7687
MEMGRAPH_ENABLED=true

# === Vector Search Tuning ===
HNSW_M=16
HNSW_EF_CONSTRUCTION=64
HNSW_EF_SEARCH=100
DEFAULT_SEARCH_TOP_K=20
DEFAULT_RERANK_CANDIDATES=50
DEFAULT_MIN_SCORE=0.40

# === Chunking ===
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# === Persistence (host bind mounts under ./data/) ===
# Postgres, Memgraph, and LightRAG state are bind-mounted to ./data/{postgres,memgraph,lightrag}
# so `docker volume prune` does not wipe project data. The dirs are gitignored.
# No env vars needed; paths are wired in docker-compose.yml. Run once before
# first `docker compose up`:
#   mkdir -p ./data/postgres ./data/memgraph ./data/lightrag
#   docker run --rm -v "$PWD/data/memgraph":/d alpine chown -R 101:101 /d

# === LLM provider (optional; used by:
#       - LightRAG entity/relation extraction at ingest
#       - query-time entity-name extraction (graph channel of /v1/search)
#       - Anthropic Contextual Retrieval blurbs (when POST /v1/documents is
#         called with `contextual_retrieval: true`; opt-in per ingest)
#     ) ===
# Local vLLM via OpenAI Responses API. host.docker.internal resolves to the
# host gateway from inside the api container (extra_hosts in docker-compose).
# If you don't run an LLM, leave LLM_BASE_URL pointing at an unreachable host
# and the api will skip LightRAG ingest cleanly (hybrid + rerank still work).
# All three uses share this single endpoint. Per-purpose env split (separate
# LLMs for ingest / query / CR blurbing) is a documented deferred refactor.
LLM_BASE_URL=http://host.docker.internal:8000
LLM_MODEL=Qwen3.6-27B-AWQ4
# Optional: API key (vLLM does not require one; set if you point at a hosted endpoint)
LLM_API_KEY=
# When false, sends chat_template_kwargs.enable_thinking=false to the LLM.
# On Qwen3.6-27B-AWQ4 this cuts a 3-word answer from ~684 output tokens / 33s
# to 3 tokens / 0.7s. Flip to true only if a test wants thinking on.
LLM_ENABLE_THINKING=false
