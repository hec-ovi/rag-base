# ============================================================
# knowledge-db — Configuration
# ============================================================
# Copy to .env and edit:  cp .env.template .env
# All values below are safe defaults. Only MODELS_DIR and
# passwords need your attention before first run.
# ============================================================

# === PostgreSQL + pgvector ===
POSTGRES_DB=knowledge
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=changeme
# 5433 to avoid conflict with any existing Postgres on the host
POSTGRES_PORT=5433

# === API Server ===
API_PORT=5050
API_WORKERS=1
API_LOG_LEVEL=info

# === Embedding Model (served by TEI) ===
EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-l-v2.0
EMBEDDING_PORT=8081

# === Reranker Model (served by TEI) ===
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_PORT=8082

# === Model Storage ===
# Absolute path on the host where HuggingFace models are cached.
# TEI downloads here on first boot, then reuses the cache.
# Two separate dirs so embed and rerank containers don't collide.
# IMPORTANT: Use absolute paths. Example: /home/youruser/models/embeddings
EMBEDDING_MODELS_DIR=/path/to/your/models/embeddings
RERANKER_MODELS_DIR=/path/to/your/models/rerankers

# === Memgraph ===
MEMGRAPH_PORT=7687
MEMGRAPH_ENABLED=true

# === Vector Search Tuning ===
HNSW_M=16
HNSW_EF_CONSTRUCTION=64
HNSW_EF_SEARCH=100
DEFAULT_SEARCH_TOP_K=20
DEFAULT_RERANK_CANDIDATES=50
DEFAULT_MIN_SCORE=0.40

# === Chunking ===
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# === Persistence (Docker named volumes) ===
PGDATA_VOLUME=ragbase_pgdata
MEMGRAPH_VOLUME=ragbase_mgdata
